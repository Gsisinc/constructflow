# GitHub Pages / production: set to your repo path so the app loads (e.g. /constructflow/)
# Leave unset or empty for localhost and root deployments.
# VITE_BASE_PATH=/constructflow/

# Base44 (enables proxy and silences "[base44] Proxy not enabled" – use your app base URL or default below)
VITE_BASE44_APP_BASE_URL=https://app.base44.com
# VITE_BASE44_APP_ID=your_base44_app_id

# AI Agent Configuration (Claude for agents + estimate generator)
VITE_CLAUDE_API_KEY=your_claude_api_key_here
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (optional; used for AI Analysis and bid doc analysis)
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Bid Discovery (SAM.gov – required for live bid search)
VITE_SAM_GOV_API_KEY=your_sam_gov_api_key_here

# Other Services
VITE_QUICKBOOKS_CLIENT_ID=your_qb_client_id
VITE_QUICKBOOKS_REDIRECT_URI=http://localhost:5173/auth/quickbooks/callback
